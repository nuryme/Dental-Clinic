# Copy to server/.env and fill in. Never commit the real .env.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/smile_dental?retryWrites=true&w=majority

# Secret for signing the app JWT (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Frontend origin(s) for CORS — comma-separated (dev + deployed)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Whoever registers with this email becomes super-admin
SUPER_ADMIN_EMAIL=
# Firebase project ID — used to verify login tokens against Google's public certs.
# Same value as the client's VITE_FIREBASE_PROJECT_ID. No service account needed.
FIREBASE_PROJECT_ID=your-firebase-project-id

# production | development (controls secure cookie + sameSite)
NODE_ENV=development
